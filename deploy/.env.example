# ============================================
# Sudoclaw QMS Production Environment Config
# ============================================
# Copy this file to .env and update values

# ============================================
# Server
# ============================================
PORT=6078

# ============================================
# PostgreSQL + TimescaleDB
# ============================================
# Use container name as host (not localhost)
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=sudowork_qms
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ============================================
# Redis
# ============================================
# Use container name as host (not localhost)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Authentication
# ============================================
JWT_SECRET=change-this-to-a-secure-random-string
ADMIN_PASSWORD=admin123

# ============================================
# CORS (comma-separated origins)
# ============================================
CORS_ORIGINS=https://your-domain.com

# ============================================
# Encryption (optional)
# ============================================
TELEMETRY_PRIVATE_KEY=
TELEMETRY_ENCRYPTION_REQUIRED=false

# ============================================
# Notifications (optional)
# ============================================
LARK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Docker Image (for CI/CD)
# ============================================
DOCKER_IMAGE=ghcr.io/sudo-ai/sudowork-qms:latest