# ============================================
# Sudoclaw QMS Production Environment Config
# ============================================
# This file is used as template when building Docker image
# Actual values should be provided via docker-compose.yml or environment

# Server
PORT=6078
HOST=0.0.0.0
NODE_ENV=production

# CORS (comma-separated origins)
CORS_ORIGINS=

# ============================================
# PostgreSQL + TimescaleDB
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sudowork_qms
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=10000

# ============================================
# Redis (Queue + Session Storage)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue Settings
QUEUE_FLUSH_INTERVAL=3000
QUEUE_BATCH_SIZE=50

# ============================================
# Authentication
# ============================================
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=24h
API_KEY_HEADER=X-API-Key
DEFAULT_API_KEY=

# Default admin password (used on first initialization)
ADMIN_PASSWORD=admin123

# ============================================
# Telemetry Data Retention
# ============================================
PERF_RETENTION_DAYS=90
CONVERSATION_RETENTION_DAYS=180

# ============================================
# Notifications (Alerts)
# ============================================
LARK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ============================================
# Encryption (Hybrid RSA + AES-GCM)
# ============================================
TELEMETRY_PRIVATE_KEY=
TELEMETRY_ENCRYPTION_REQUIRED=false
TELEMETRY_ENCRYPTION_ALGORITHM=hybrid-v1

# ============================================
# Admin Frontend
# ============================================
SERVE_ADMIN=true

# ============================================
# Logging
# ============================================
LOG_LEVEL=info