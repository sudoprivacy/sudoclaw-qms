# ============================================
# Sudoclaw QMS Environment Configuration Example
# ============================================
# Copy this file to .env and update values for your environment

# Server
PORT=6078
HOST=0.0.0.0
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# PostgreSQL + TimescaleDB
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sudoclaw_qms
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=10000

# ============================================
# Redis (Queue + Session Storage)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue Settings - how often to flush telemetry data to DB
QUEUE_FLUSH_INTERVAL=3000  # milliseconds (3 seconds)
QUEUE_BATCH_SIZE=50        # max items per batch insert

# ============================================
# Authentication
# ============================================
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=24h
API_KEY_HEADER=X-API-Key
DEFAULT_API_KEY=sk-your-api-key-here

# Default admin user password (used on first initialization)
# Change this in production environments!
ADMIN_PASSWORD=admin123

# ============================================
# Telemetry Data Retention
# ============================================
PERF_RETENTION_DAYS=90
CONVERSATION_RETENTION_DAYS=180
AGGREGATION_CRON=0 1 * * *
CLEANUP_CRON=0 2 * * *

# ============================================
# Notifications (Alerts)
# ============================================
# Dingtalk Webhook
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=SECxxx

# Lark Webhook
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxx

# ============================================
# Encryption (Hybrid RSA + AES-GCM)
# ============================================
# RSA-2048 private key PEM for telemetry decryption
TELEMETRY_PRIVATE_KEY=
TELEMETRY_ENCRYPTION_REQUIRED=false
TELEMETRY_ENCRYPTION_ALGORITHM=hybrid-v1

# ============================================
# Admin Frontend
# ============================================
SERVE_ADMIN=false

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
